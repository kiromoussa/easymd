{
  "name": "easymd",
  "version": "0.1.0",
  "description": "Google Docs for markdown — collaborate on the actual .md file in your repo",
  "type": "module",
  "bin": {
    "easymd": "./bin/easymd.js"
  },
  "scripts": {
    "build": "node scripts/build.js",
    "postinstall": "node scripts/build.js",
    "prepublishOnly": "npm run build",
    "start": "node bin/easymd.js"
  },
  "keywords": [
    "markdown",
    "collaboration",
    "crdt",
    "agents",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "dependencies": {
    "chokidar": "^4.0.3",
    "express": "^4.21.2",
    "open": "^10.1.0",
    "ws": "^8.18.0",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "esbuild": "^0.25.0",
    "marked": "^15.0.7",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
