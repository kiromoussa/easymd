{
  "name": "easymd-cli",
  "version": "0.1.5",
  "description": "Google Docs for markdown — collaborate on the actual .md file in your repo, live with humans and AI agents. CLI: login, auto-sync, and open .md files for real-time editing.",
  "type": "module",
  "bin": {
    "easymd": "./bin/easymd.js",
    "easymd-cli": "./bin/easymd.js"
  },
  "files": [
    "bin",
    "src",
    "client",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "node scripts/build.js",
    "postinstall": "node scripts/build.js > /dev/null 2>&1 || true",
    "prepublishOnly": "npm run build",
    "start": "node bin/easymd.js",
    "web:dev": "npm run dev --prefix web",
    "web:build": "npm run build --prefix web"
  },
  "keywords": [
    "markdown",
    "collaboration",
    "crdt",
    "agents",
    "claude",
    "cursor"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^4.0.3",
    "open": "^10.1.0",
    "zod": "^4.4.3"
  },
  "optionalDependencies": {
    "express": "^4.21.2",
    "ws": "^8.18.0",
    "y-websocket": "^2.1.0",
    "yjs": "^13.6.24"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.8.0",
    "@codemirror/lang-markdown": "^6.3.2",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.36.4",
    "esbuild": "^0.25.0",
    "marked": "^15.0.7",
    "y-codemirror.next": "^0.3.5",
    "y-protocols": "^1.0.6",
    "y-websocket": "^2.1.0"
  },
  "engines": {
    "node": ">=18"
  }
}
