# Get keys at https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# WebSocket collab server for the live demo
NEXT_PUBLIC_COLLAB_WS_URL=ws://localhost:3848
COLLAB_PORT=3848

# Shared secret for collab WebSocket access tickets. The Next API issues a short-lived
# HMAC ticket (only for rooms the signed-in user owns); the collab server and MCP server
# verify it. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COLLAB_SECRET=replace-with-a-long-random-string

# Secret for signing long-lived easymd CLI tokens (issued at `easymd login`, verified by
# the /api/cli/* routes). Generate the same way. Falls back to COLLAB_SECRET if unset.
CLI_TOKEN_SECRET=replace-with-a-long-random-string

# Supabase — durable persistence for the collaborative demo document.
# The collab server runs server-side and uses the SERVICE ROLE key (never sent to the
# browser); it bypasses RLS. Get these from Supabase Dashboard → Project Settings → API.
# Local dev (after `supabase start`): use the local API URL + local service_role key
# printed by `supabase start` (and `supabase status`).
# If unset, the collab server keeps documents in memory only (reset on restart).
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Public Supabase keys (safe for the browser) — available for future client-side use.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# PostHog product analytics (browser). Use the PUBLIC project key (phc_...), safe to ship
# to the client — NOT a personal key (phx_...). Get it at PostHog → Settings → Project.
# If unset, analytics is a no-op (builds and local dev work fine without it).
NEXT_PUBLIC_POSTHOG_KEY=phc_...
# Requests are reverse-proxied through this app's origin (see next.config.ts rewrites) to
# survive ad-blockers. Leave as /ingest; set a direct host (https://us.i.posthog.com) only
# to bypass the proxy. Proxy hosts in next.config.ts are US — switch them for EU projects.
NEXT_PUBLIC_POSTHOG_HOST=/ingest

# MCP — the account AI agents act on behalf of. Set this to your Clerk user id (shown
# on the easymd dashboard) so docs an agent creates land in your account. This belongs
# in the MCP server's environment (see .cursor/mcp.json), not the browser.
# EASYMD_OWNER_ID=user_xxxxxxxxxxxxxxxxxxxxxxxx
